{
  "document_type": "protocol-retrospective",
  "display_name": "Retrospective Cohort Protocol",
  "plugin": "ProtocolPlugin",
  "sections": [
    {
      "id": "01_background",
      "title": "Background and Rationale",
      "mode": "llm",
      "kind": "body",
      "word_target": 800,
      "depends_on": [],
      "quality_category": "evidence_grounding",
      "llm_prompt_hint": "Summarize disease context, care gaps, and justification for a retrospective design."
    },
    {
      "id": "02_objectives",
      "title": "Objectives",
      "mode": "hybrid",
      "kind": "body",
      "word_target": 500,
      "depends_on": [
        "01_background"
      ],
      "quality_category": "endpoint_clarity",
      "llm_prompt_hint": "State primary and secondary objectives aligned to the study rationale."
    },
    {
      "id": "03_study_design",
      "title": "Study Design",
      "mode": "hybrid",
      "kind": "body",
      "word_target": 700,
      "depends_on": [
        "02_objectives"
      ],
      "quality_category": "regulatory_completeness",
      "llm_prompt_hint": "Describe the retrospective cohort design, setting, time window, and data sources."
    },
    {
      "id": "04_eligibility",
      "title": "Eligibility Criteria",
      "mode": "structured",
      "kind": "body",
      "word_target": 450,
      "depends_on": [
        "03_study_design"
      ],
      "quality_category": "regulatory_completeness",
      "llm_prompt_hint": "List inclusion and exclusion criteria that match the available retrospective data."
    },
    {
      "id": "05_procedures",
      "title": "Study Procedures",
      "mode": "structured",
      "kind": "body",
      "word_target": 650,
      "depends_on": [
        "03_study_design",
        "04_eligibility"
      ],
      "quality_category": "operational_feasibility",
      "llm_prompt_hint": "Outline chart review workflow, abstraction steps, and quality control procedures."
    },
    {
      "id": "06_endpoints",
      "title": "Outcome Measures",
      "mode": "hybrid",
      "kind": "body",
      "word_target": 500,
      "depends_on": [
        "02_objectives",
        "04_eligibility"
      ],
      "quality_category": "endpoint_clarity",
      "llm_prompt_hint": "Define primary and secondary endpoints with precise retrospective measurement rules."
    },
    {
      "id": "csa:table1",
      "title": "CSA Table 1 — Baseline Characteristics",
      "mode": "structured",
      "kind": "csa",
      "word_target": 0,
      "depends_on": ["04_eligibility"],
      "quality_category": "analysis_rigor",
      "llm_prompt_hint": ""
    },
    {
      "id": "csa:survival",
      "title": "CSA Survival Analysis",
      "mode": "structured",
      "kind": "csa",
      "word_target": 0,
      "depends_on": ["06_endpoints"],
      "quality_category": "analysis_rigor",
      "llm_prompt_hint": ""
    },
    {
      "id": "csa:adverse_events",
      "title": "CSA Adverse Events",
      "mode": "structured",
      "kind": "csa",
      "word_target": 0,
      "depends_on": ["05_procedures"],
      "quality_category": "analysis_rigor",
      "llm_prompt_hint": ""
    },
    {
      "id": "07_statistical",
      "title": "Statistical Analysis Plan",
      "mode": "llm",
      "kind": "body",
      "word_target": 900,
      "depends_on": [
        "05_procedures",
        "06_endpoints",
        "csa:table1",
        "csa:survival",
        "csa:adverse_events"
      ],
      "quality_category": "analysis_rigor",
      "llm_prompt_hint": "Specify descriptive analyses, confounding control, missing data handling, and sensitivity analyses. Use CSA statistical outputs as grounding data."
    },
    {
      "id": "08_ethics",
      "title": "Ethical Considerations",
      "mode": "structured",
      "kind": "body",
      "word_target": 350,
      "depends_on": [
        "03_study_design"
      ],
      "quality_category": "regulatory_completeness",
      "llm_prompt_hint": "Cover IRB review, consent waiver rationale, privacy safeguards, and data security."
    },
    {
      "id": "09_data_mgmt",
      "title": "Data Management",
      "mode": "structured",
      "kind": "body",
      "word_target": 400,
      "depends_on": [
        "05_procedures",
        "08_ethics"
      ],
      "quality_category": "operational_feasibility",
      "llm_prompt_hint": "Describe storage, de-identification, access control, audit trail, and retention rules."
    },
    {
      "id": "10_references",
      "title": "References",
      "mode": "structured",
      "kind": "back_matter",
      "word_target": 0,
      "depends_on": [
        "01_background",
        "07_statistical",
        "08_ethics",
        "09_data_mgmt"
      ],
      "quality_category": "evidence_grounding",
      "llm_prompt_hint": "Compile cited literature and standards referenced across the protocol."
    }
  ],
  "quality": {
    "pass_threshold": 85,
    "max_refinement_iterations": 3,
    "categories": [
      "regulatory_completeness",
      "evidence_grounding",
      "endpoint_clarity",
      "operational_feasibility",
      "analysis_rigor"
    ]
  },
  "compilation": {
    "format": "docx",
    "renderer": "bookshelf",
    "preamble": [
      "title_page",
      "synopsis_table"
    ],
    "postprocess": [
      "cwyw_tags",
      "figure_replacement"
    ]
  }
}
